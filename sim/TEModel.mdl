		  Object {
		    $ObjectID		    440
		    $ClassName		    "Simulink.dialog.TabContainer"
		    Array {
		    Type		    "Simulink.dialog.Tab"
		    Dimension		    3
		    Object {
		    $ObjectID		    441
		    Prompt		    "General"
		    Array {
		    Type		    "Simulink.dialog.parameter.Control"
		    Dimension		    4
		    Object {
		    $ObjectID		    442
		    $ClassName		    "Simulink.dialog.parameter.Popup"
		    PromptLocation	    "top"
		    Name		    "switch_mode"
		    }
		    Object {
